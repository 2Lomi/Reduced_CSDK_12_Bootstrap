{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build VDataEditor",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/VDataEditor/VDataEditor.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build ConsoleApp1",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/ConsoleApp1/ConsoleApp1.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}